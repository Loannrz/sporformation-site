# Supabase — Settings → API : Project URL + anon public + service_role
# Dupliquer URL et anon ici (sans préfixe NEXT_PUBLIC_) : lecture runtime côté serveur,
# évite une ancienne URL figée dans .next après modification du .env.
SUPABASE_URL=
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=SPORFORMATION <onboarding@resend.dev>
DIRECTOR_EMAIL=direction@sporformation.fr

# Liens dans les mails messagerie / annonces (URL publique sans slash final)
APP_ORIGIN=http://localhost:3000

# Optionnel : page d’entrée du portail candidature dans les mails inscription (sinon APP_ORIGIN/fr)
# NEXT_PUBLIC_INSCRIPTION_ENTRY_URL=https://candidatures.example.com/fr

# Optionnel : domaine vérifié côté Resend pour la prod
